FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL=http://localhost:8000
ARG VITE_JIRA_URL=""
ARG VITE_GITLAB_URL=""
ARG VITE_CONFLUENCE_URL=""
ARG VITE_GITLAB_PROJECT_PATH=""
RUN VITE_API_URL=$VITE_API_URL \
    VITE_JIRA_URL=$VITE_JIRA_URL \
    VITE_GITLAB_URL=$VITE_GITLAB_URL \
    VITE_CONFLUENCE_URL=$VITE_CONFLUENCE_URL \
    VITE_GITLAB_PROJECT_PATH=$VITE_GITLAB_PROJECT_PATH \
    npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
